# ipctl용 예시 설정 (필요한 것만 채우면 됨)
#
# 사용법:
#   cp scripts/ips.example.env scripts/ips.env
#   vim scripts/ips.env
#   bash scripts/ipctl.sh scan
#   bash scripts/ipctl.sh apply

# 온프 ArgoCD가 EKS를 원격 관리할 때 쓰는 EKS API 서버 주소
# applications/cloud-prod/*.yaml 의 destination.server 에 사용
EKS_CLUSTER_URL=https://44.234.135.248
# (실제 EKS 엔드포인트 예: https://XXXXX.eks.<region>.amazonaws.com)

# cloud-prod(EKS) fluent-bit → onprem loki(NodePort)로 push
ONPREM_LOKI_NODE_IP=192.168.1.147  # 'kubectl label node eks-worker1 loki=monitoring-loki --overwrite' 가 적용된  노드ip
ONPREM_LOKI_NODEPORT=31000

# cloud-prod prometheus remoteWrite → onprem prometheus(or mimir, victoria)로 전송
ONPREM_PROM_REMOTEWRITE_IP=192.168.1.147
ONPREM_PROM_REMOTEWRITE_PORT=9090

# onprem photo NFS 서버
ONPREM_NFS_SERVER_IP=192.168.1.147  # nfs 설치된 ip 

# onprem MetalLB 풀 주소 (gateway LB 등에 할당되는 대역)
# clusters/onprem/dev/platform/metallb-system/values.yaml 의 addresses 에 사용
ONPREM_METALLB_POOL_IP=192.168.1.146

# onprem gateway LoadBalancerIP (MetalLB 사용 시, 풀에 있는 IP여야 함)
ONPREM_GATEWAY_LB_IP=192.168.1.146

# redis-session endpoints IP (사용 중이면)
ONPREM_REDIS_SESSION_IP=192.168.90.84

# ProxySQL 커넥터에서 참조하는 IP (사용 중이면)
PROXYSQL_IP=192.168.1.50

# Loki NFS values (platform/loki/values-nfs.yaml)에서 참조하는 NFS 서버
# LOKI_NFS_SERVER_IP=192.168.90.94 일단은 안씀. 

